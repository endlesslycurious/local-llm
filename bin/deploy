#!/bin/sh
# Deploy a model's LaunchDaemon plist.
# Usage: sudo bin/deploy <plist-name>
# e.g.   sudo bin/deploy gemma-4-26B-A4B-it-UD-Q4_K_M.plist

DEST=/Library/LaunchDaemons/local.llama.server.plist
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
DAEMONS_DIR="$SCRIPT_DIR/../daemons"

if [ -z "$1" ]; then
    echo "Usage: $0 <plist-name>"
    echo ""
    echo "Available:"
    ls "$DAEMONS_DIR"
    exit 1
fi

SRC="$DAEMONS_DIR/$1"

if [ ! -f "$SRC" ]; then
    echo "Error: $SRC not found"
    exit 1
fi

cp "$SRC" "$DEST"
chown root:wheel "$DEST"
chmod 644 "$DEST"

echo "Deployed $1 -> $DEST"
