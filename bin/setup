#!/bin/sh
# Set up symlinks from ~/.omlx/ to version-controlled config files and firewall permissions.
# Usage: sudo bin/setup

set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CONFIG_DIR="$SCRIPT_DIR/../config"
OMLX_DIR="$HOME/.omlx"

mkdir -p "$OMLX_DIR"

# Link config files from ../config to ~/.omlx/
ln -sf "$CONFIG_DIR/settings.json" "$OMLX_DIR/settings.json"
ln -sf "$CONFIG_DIR/model_settings.json" "$OMLX_DIR/model_settings.json"

# Add macOS firewall permission for incoming connections
security set-appfirewall-rule -t incoming --app-firewall allow --process "omlx-server"
